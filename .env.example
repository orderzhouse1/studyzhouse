# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal Express URL used by Next.js rewrites (browser hits /api/v1 on :3000)
API_INTERNAL_URL=http://127.0.0.1:4000

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Redis (Phase 1 stub — optional)
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# Auth — JWT HttpOnly cookie (Phase 2)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace_me_with_at_least_32_random_chars!!
JWT_EXPIRES_IN=12h

# -----------------------------------------------------------------------------
# Legacy placeholders (later phases)
# -----------------------------------------------------------------------------
SESSION_SECRET=change_me
JWT_REFRESH_SECRET=change_me
COOKIE_DOMAIN=localhost

YOUTUBE_API_KEY=

CLIQ_ALIAS=
CLIQ_DISPLAY_NAME=
CLIQ_INSTRUCTIONS=

UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SENTRY_DSN=
