# =============================================================================
# Studyhouse — مثال متغيرات البيئة (لا تُرفع أسرار حقيقية إلى Git)
# =============================================================================
# انسخ إلى `.env` وولّد كل القيم السرية بنفسك (مثل openssl rand -hex 32).
# أي قيمة أدناه هي placeholder صريح وليست للإنتاج.

NODE_ENV=development

# -----------------------------------------------------------------------------
# Next.js (الواجهة)
# -----------------------------------------------------------------------------
# عنوان الواجهة العام — اختياري إذا لم يُستخدم في الكود بعد للروابط المطلقة.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# عنوان Express الذي يعيد توجيهه Next عبر rewrites عندما يطلب المتصفح /api/v1/*
# يجب أن يصل إليه خادم Next أثناء التشغيل وبناء الصفحات الديناميكية التي تجلب من API.
API_INTERNAL_URL=http://127.0.0.1:4000

# Middleware في Next يتحقق من توقيع JWT للمسارات المحمية — يجب أن يطابق JWT_ACCESS_SECRET في API.
# يمكن تعريف نفس القيمة هنا أو في جذر المستودع (.env)؛ apps/web/next.config.ts يدمج قيمة JWT من ملفات .env الشائعة.

# -----------------------------------------------------------------------------
# Express API (apps/api) — يُحمّلها loadEnv() في apps/api/src/config/env.ts
# -----------------------------------------------------------------------------
API_PORT=4000

# أصل الواجهة المسموح لـ CORS + ملفات تعريف الارتباط — يجب أن يطابق URL المتصفح (مثال إنتاج: https://app.example.com)
CLIENT_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# مطلوب: 32 حرفًا على الأقل — ولّد عشوائيًا ولا تعيد استخدام هذا النص.
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_32_PLUS_RANDOM_CHARS_WITH_OPENSSL_OR_SIMILAR

JWT_EXPIRES_IN=12h

# اختياري (≥32 حرفًا): pepper مستقل لاشتقاق بصمة أكواد التفعيل في قاعدة البيانات.
# إن لم يُضبط، يُستخدم JWT_ACCESS_SECRET كاحتياط (غير مثالي لكن متوافق).
# تحذير: تغيير هذه القيمة بعد إنشاء أكواد حقيقية يُبطل المطابقة للـ hashes القديمة ما لم تُعاد إصدار الأكواد.
ACTIVATION_CODE_PEPPER=CHANGE_ME_GENERATE_ANOTHER_32_PLUS_CHAR_SECRET_INDEPENDENT_FROM_JWT

# -----------------------------------------------------------------------------
# اختبارات التكامل (Vitest في apps/api فقط) — لا تضع قيمة إلا لقاعدة عزل منفصلة
# -----------------------------------------------------------------------------
# TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST/test_db?sslmode=require

# -----------------------------------------------------------------------------
# Redis — غير موصول في الكود الحالي (stub). للمراحل اللاحقة أو حدود المعدل موزعة.
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# YouTube Data API v3 — خادم فقط (apps/api)، لا يُعرض للمتصفح
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# متغيرات مستقبلية / غير مستخدمة حاليًا في apps/api/src/config/env.ts
# (لا تُقرأ من loadEnv — احتفظ بها هنا فقط إذا احتجتها لاحقًا أو لأدوات خارجية)
# -----------------------------------------------------------------------------
# SESSION_SECRET=unused_by_api_currently
# JWT_REFRESH_SECRET=unused_by_api_currently
# COOKIE_DOMAIN=.example.com — غير مُقرأ من loadEnv() حاليًا؛ cookieAuth يضبط النطاق من الطلب في الإنتاج

# -----------------------------------------------------------------------------
# رفع ملفات / مراقبة — غير مدمجة في مسار API الرئيسي بعد (أسماء شائعة للمراحل القادمة)
# -----------------------------------------------------------------------------
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SENTRY_DSN=

# -----------------------------------------------------------------------------
# CliQ — مصدر الحقيقة لعرض التعليمات للمستخدم هو إعدادات المنصة في لوحة السوبر أدمن
# (AppSetting / platform_governance)، وليس المتغيرات التالية. لا تُستخدم في كود API الحالي.
# -----------------------------------------------------------------------------
