# =============================================================================
# Studyhouse — مثال متغيرات البيئة (لا تُرفع أسرار حقيقية إلى Git)
# =============================================================================
# انسخ إلى `.env` وولّد كل القيم السرية بنفسك (مثل openssl rand -hex 32).
# أي قيمة أدناه هي placeholder صريح وليست للإنتاج.
#
# للإنتاج (Google Cloud Run وغيره): راجع قسم «الإنتاج» أدناه و
# docs/PRODUCTION_DEPLOYMENT_AUDIT.md و docs/PRODUCTION_DEPLOY_VERIFY.md

NODE_ENV=development

# -----------------------------------------------------------------------------
# Next.js (الواجهة) — التطوير المحلي
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# عنوان Express من وجهة نظر خادم Next (SSR + rewrites في next.config.ts).
# التطوير: API على نفس الجهاز.
API_INTERNAL_URL=http://127.0.0.1:4000

# Middleware في Next — يجب أن يطابق JWT_ACCESS_SECRET في API.
# apps/web/next.config.ts يمكنه قراءة JWT من .env في جذر المستودع.

# -----------------------------------------------------------------------------
# Express API (apps/api) — يُحمّلها loadEnv() في apps/api/src/config/env.ts
# -----------------------------------------------------------------------------
API_PORT=4000

# أصل المتصفح — CORS + روابط الرفع + إعادة توجيه OAuth بعد النجاح.
CLIENT_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_32_PLUS_RANDOM_CHARS_WITH_OPENSSL_OR_SIMILAR

JWT_EXPIRES_IN=12h

ACTIVATION_CODE_PEPPER=CHANGE_ME_GENERATE_ANOTHER_32_PLUS_CHAR_SECRET_INDEPENDENT_FROM_JWT

# -----------------------------------------------------------------------------
# Google OAuth (API) — مطلوب لتسجيل Google للطلاب
# -----------------------------------------------------------------------------
# التطوير المحلي (يجب أن يطابق Google Cloud Console للمشروع):
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# البريد — OTP التسجيل ونسيت كلمة المرور (API)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Studyhouse <noreply@your-domain.com>

# -----------------------------------------------------------------------------
# اختبارات التكامل (Vitest) — قاعدة عزل فقط، ليس الإنتاج
# -----------------------------------------------------------------------------
# TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST/test_db?sslmode=require

# -----------------------------------------------------------------------------
# Redis — stub (غير موصول حاليًا)
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# YouTube Data API v3 — خادم فقط (استيراد قوائم في لوحة الإدارة)
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=

# =============================================================================
# الإنتاج — لا تستخدم localhost في أسرار Cloud Run / Secret Manager
# =============================================================================
# استبدل YOUR_PRODUCTION_DOMAIN بالنطاق الفعلي مع HTTPS، مثال: studyhouse.example.com
#
# NODE_ENV=production
#
# --- Next (خدمة الويب) ---
# API_INTERNAL_URL:
#   • حاوية واحدة (Next + API معًا على 4000): http://127.0.0.1:4000
#   • خدمتا Cloud Run منفصلتان: عنوان URL الداخلي/العام لخدمة API، مثال:
#     https://studyhouse-api-xxxxx-uc.a.run.app
#     (يجب أن يصل خادم Next إليه — ليس localhost إلا إن كان API في نفس الحاوية)
# JWT_ACCESS_SECRET=<نفس القيمة في خدمة API>
#
# --- API (خدمة Express) ---
# CLIENT_ORIGIN=https://YOUR_PRODUCTION_DOMAIN
# DATABASE_URL=postgresql://...?sslmode=require
# JWT_ACCESS_SECRET=<≥32 حرفًا عشوائي — نفس قيمة Next>
# JWT_EXPIRES_IN=12h
# ACTIVATION_CODE_PEPPER=<≥32 حرفًا مستقل — لا تُغيّره بعد إصدار أكواد حقيقية>
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=https://YOUR_PRODUCTION_DOMAIN/api/v1/auth/google/callback
# RESEND_API_KEY=...
# EMAIL_FROM=...
# YOUTUBE_API_KEY=...   (اختياري)
#
# Google Cloud Console → OAuth client:
#   Authorized JavaScript origins: https://YOUR_PRODUCTION_DOMAIN
#   Authorized redirect URIs:
#     https://YOUR_PRODUCTION_DOMAIN/api/v1/auth/google/callback
# لا تعتمد على http://localhost:3000 في إنتاج.
#
# الكوكي: NODE_ENV=production يفعّل Secure — يتطلب HTTPS على CLIENT_ORIGIN.

# -----------------------------------------------------------------------------
# متغيرات غير مستخدمة في loadEnv() حاليًا
# -----------------------------------------------------------------------------
# SESSION_SECRET=unused_by_api_currently
# JWT_REFRESH_SECRET=unused_by_api_currently
# COOKIE_DOMAIN=.example.com

# -----------------------------------------------------------------------------
# رفع ملفات / مراقبة — مراحل لاحقة
# -----------------------------------------------------------------------------
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SENTRY_DSN=

# CliQ: إعدادات المنصة في لوحة السوبر أدمن (platform_governance)، ليس env.
